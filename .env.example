# ==============================================
# CarbonLedger - Exemplo de configuração Sepolia
# ==============================================

# RPC da rede Sepolia
# Pode usar um RPC público ou um endpoint da Infura, Alchemy ou outro provedor.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key da conta deployer.
# Esta conta paga o deploy, setup, funding e transferência de ownership.
# Nunca envie esta chave para o GitHub.
SEPOLIA_DEPLOYER_PRIVATE_KEY=0xCOLOQUE_A_PRIVATE_KEY_DO_DEPLOYER_AQUI

# API Key do Etherscan.
# Opcional para deploy e testes.
# Necessária apenas para verificar contratos no Etherscan.
ETHERSCAN_API_KEY=

# Endereços públicos das contas usadas no MVP.
# Podem ser gerados com:
# npx hardhat run .\scripts\gerar_carteiras_sepolia.ts

SEPOLIA_ADMIN_ADDRESS=0xEnderecoDoAdmin
SEPOLIA_PROPONENTE_ADDRESS=0xEnderecoDoProponente
SEPOLIA_VALIDADOR1_ADDRESS=0xEnderecoDoValidador1
SEPOLIA_VALIDADOR2_ADDRESS=0xEnderecoDoValidador2
SEPOLIA_COMPRADOR_ADDRESS=0xEnderecoDoComprador
SEPOLIA_USUARIO_EXTRA_ADDRESS=0xEnderecoUsuarioExtra

# Valores usados pelo script de funding.
SEPOLIA_FUND_AMOUNT_ETH=0.05
SEPOLIA_MIN_BALANCE_ETH=0.02